<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="VinhKhanh.App.MainPage"
             Title="Bản đồ Vĩnh Khánh">

    <Grid RowDefinitions="Auto,Auto,*" Padding="12" RowSpacing="10">
        <HorizontalStackLayout Spacing="8">
            <Picker x:Name="LangPicker" Title="Ngôn ngữ" WidthRequest="120" SelectedIndexChanged="OnLangChanged" />
            <Button Text="Đồng bộ POI" Clicked="OnSyncClicked" />
            <Button x:Name="TrackBtn" Text="Bật GPS" Clicked="OnTrackClicked" />
        </HorizontalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="4">
            <Label x:Name="StatusLabel" FontSize="13" TextColor="#444" />
            <Label x:Name="NearestLabel" FontSize="15" FontAttributes="Bold" TextColor="#c2410c" />
        </VerticalStackLayout>

        <maps:Map x:Name="StreetMap" Grid.Row="2" IsShowingUser="True" MapType="Street" />
    </Grid>
</ContentPage>
