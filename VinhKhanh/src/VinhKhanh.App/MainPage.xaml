<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="VinhKhanh.App.MainPage"
             Title="Ban do Vinh Khanh"
             BackgroundColor="#F8FAFC">

    <Grid>
        <mapsui:MapView x:Name="StreetMap"
                        PinClicked="OnPinClicked"
                        MapClicked="OnMapClicked" />

        <Grid RowDefinitions="Auto, *, Auto" ColumnDefinitions="*, Auto" Padding="16">
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    Background="#FFFFFF"
                    StrokeShape="RoundRectangle 16"
                    Padding="12,8"
                    HorizontalOptions="Center"
                    Shadow="{Shadow Brush=#000000, Offset='0,4', Opacity=0.1, Radius=8}">

                <HorizontalStackLayout Spacing="12">
                    <Picker x:Name="LangPicker"
                            Title="Ngon ngu"
                            WidthRequest="140"
                            TextColor="#0F172A"
                            TitleColor="#64748B"
                            FontAttributes="Bold"
                            SelectedIndexChanged="OnLangChanged" />

                    <Button x:Name="SyncBtn" Text="Dong bo"
                            Clicked="OnSyncClicked"
                            BackgroundColor="#0F172A"
                            TextColor="#FFFFFF"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Padding="16,0"
                            HeightRequest="40"/>
                </HorizontalStackLayout>
            </Border>

            <Button x:Name="TrackBtn"
                    Grid.Row="1" Grid.Column="1"
                    Text="Bat GPS"
                    Clicked="OnTrackClicked"
                    VerticalOptions="End"
                    Margin="0,0,0,16"
                    WidthRequest="110" HeightRequest="56"
                    CornerRadius="28"
                    BackgroundColor="#EA580C" TextColor="#FFFFFF" FontAttributes="Bold"
                    Shadow="{Shadow Brush=#EA580C, Offset='0,4', Opacity=0.3, Radius=8}" />

            <VerticalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="16">
                <Border Stroke="#E2E8F0" StrokeThickness="1"
                        Background="#0F172A"
                        StrokeShape="RoundRectangle 16"
                        Padding="16"
                        Shadow="{Shadow Brush=#000000, Offset='0,4', Opacity=0.15, Radius=8}">
                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                        <ActivityIndicator IsRunning="True" Color="#EA580C" WidthRequest="20" HeightRequest="20"/>
                        <VerticalStackLayout>
                            <Label x:Name="StatusLabel" FontSize="13" TextColor="#CBD5E1" FontAttributes="Bold" />
                            <Label x:Name="NearestLabel" FontSize="15" FontAttributes="Bold" TextColor="#FFFFFF" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Border x:Name="PoiDetailCard"
                        IsVisible="False"
                        Stroke="#E2E8F0" StrokeThickness="1"
                        Background="#FFFFFF"
                        StrokeShape="RoundRectangle 16"
                        Padding="20"
                        Shadow="{Shadow Brush=#000000, Offset='0,8', Opacity=0.15, Radius=16}">

                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="6">
                        <Label Text="DIEM GAN NHAT" FontSize="12" TextColor="#EA580C" FontAttributes="Bold" Grid.Row="0" Grid.Column="0" />
                        <Label x:Name="PoiTitleLabel" FontSize="22" FontAttributes="Bold" TextColor="#0F172A" Grid.Row="1" Grid.Column="0" />
                        <Label x:Name="PoiDescLabel" FontSize="15" TextColor="#475569" LineBreakMode="WordWrap" MaxLines="3" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"/>

                        <Button Text="Doc am thanh"
                                BackgroundColor="#0F172A"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                CornerRadius="8"
                                Clicked="OnReadAudioClicked"
                                Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                VerticalOptions="Center"
                                HeightRequest="48"
                                Padding="16,0"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
