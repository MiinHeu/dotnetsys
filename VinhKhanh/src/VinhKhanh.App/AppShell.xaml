<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanh.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanh.App"
    Title="Phố ẩm thực Vĩnh Khánh">

    <TabBar>
        <ShellContent Title="Bản đồ" ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        <ShellContent Title="Tour" ContentTemplate="{DataTemplate local:ToursPage}" Route="Tours" />
        <ShellContent Title="AI" ContentTemplate="{DataTemplate local:ChatPage}" Route="Chat" />
        <ShellContent Title="QR" ContentTemplate="{DataTemplate local:QrScanPage}" Route="Qr" />
        <ShellContent Title="Cài đặt" ContentTemplate="{DataTemplate local:SettingsPage}" Route="Settings" />
    </TabBar>
</Shell>
