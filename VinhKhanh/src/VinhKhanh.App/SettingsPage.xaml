<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanh.App.SettingsPage"
             Title="Cài đặt">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Label Text="URL API (có / cuối hoặc không đều được)" FontAttributes="Bold" />
            <Entry x:Name="ApiUrlEntry" Placeholder="http://10.0.2.2:5283/" />
            
            <Label Text="Hệ số bán kính geofence (1 = mặc định)" />
            <Entry x:Name="RadiusMultEntry" Keyboard="Numeric" Placeholder="1" />
            
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="Bật mô phỏng lộ trình GPS (.NET Mock)" VerticalOptions="Center" />
                <Switch x:Name="MockGpsSwitch" />
            </HorizontalStackLayout>
            <Label FontSize="11" TextColor="#999"
                   Text="Bật: blue-dot tự đi qua các POI rồi quay lại, loop liên tục."
                   IsVisible="{Binding IsToggled, Source={x:Reference MockGpsSwitch}}" />

            <BoxView HeightRequest="1" Color="#DDD" Margin="0,4" />
            
            <Button Text="Lưu" Clicked="OnSave" />
            <Label x:Name="HintLabel" FontSize="12" TextColor="#666"
                   Text="Android emulator: 10.0.2.2 thay localhost. Máy thật: IP LAN của PC." />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
