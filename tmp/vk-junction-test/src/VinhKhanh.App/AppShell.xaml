<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanh.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanh.App"
    Title="Vinh Khanh"
    BackgroundColor="#FFFFFF"
    TabBarBackgroundColor="#FFFFFF"
    TabBarForegroundColor="#FF5A1F"
    TabBarTitleColor="#111827"
    TabBarUnselectedColor="#9CA3AF">

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid Padding="0,10">
                <Label Text="{Binding Title}" HorizontalOptions="Center" VerticalOptions="Center"
                       FontAttributes="Bold" FontSize="14" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <TabBar>
        <ShellContent Title="Ban do" ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        <ShellContent Title="Lo trinh" ContentTemplate="{DataTemplate local:ToursPage}" Route="Tours" />
        <ShellContent Title="Chatbot" ContentTemplate="{DataTemplate local:ChatPage}" Route="Chat" />
        <ShellContent Title="Scan QR" ContentTemplate="{DataTemplate local:QrScanPage}" Route="Qr" />
        <ShellContent Title="Cai dat" ContentTemplate="{DataTemplate local:SettingsPage}" Route="Settings" />
    </TabBar>
</Shell>
