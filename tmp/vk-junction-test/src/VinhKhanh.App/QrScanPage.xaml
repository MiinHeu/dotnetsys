<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="VinhKhanh.App.QrScanPage"
             Title="Quet QR POI">
    <Grid RowDefinitions="Auto,*,Auto" Padding="0">
        <Label x:Name="StatusLabel"
               Padding="12"
               Text="Huong camera vao ma QR (vk-poi-123 hoac URL co /poi/123)" />

        <zxing:CameraBarcodeReaderView x:Name="Scanner"
                                       Grid.Row="1"
                                       IsDetecting="True"
                                       BarcodesDetected="OnBarcodesDetected" />

        <Grid Grid.Row="2" Padding="12" ColumnDefinitions="*,Auto" ColumnSpacing="8" BackgroundColor="#FFFFFF">
            <Entry x:Name="ManualCodeEntry"
                   Placeholder="Nhap ma QR neu camera khong kha dung"
                   ReturnType="Done"
                   Completed="OnManualSubmit"
                   ClearButtonVisibility="WhileEditing" />
            <Button Grid.Column="1" Text="Xu ly" Clicked="OnManualSubmit" />
        </Grid>
    </Grid>
</ContentPage>
