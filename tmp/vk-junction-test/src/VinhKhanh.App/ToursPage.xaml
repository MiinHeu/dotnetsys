<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanh.App.ToursPage"
             Title="Danh sach lo trinh"
             BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="Auto,*">
        <Border StrokeThickness="0" Background="#FFFFFF" Padding="20,24,20,16"
                Shadow="{Shadow Brush=#000000, Offset='0,4', Opacity=0.03, Radius=4}">
            <VerticalStackLayout Spacing="4">
                <Label Text="Kham pha" FontSize="14" TextColor="#EA580C" FontAttributes="Bold" TextTransform="Uppercase"/>
                <Label Text="Danh sach lo trinh" FontSize="28" FontAttributes="Bold" TextColor="#0F172A" />
                <Label Text="Goi y lo trinh tham quan am thuc" FontSize="15" TextColor="#475569" />
            </VerticalStackLayout>
        </Border>

        <RefreshView Grid.Row="1" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView x:Name="TourList" ItemsSource="{Binding Tours}" Padding="16,24,16,40">
                <CollectionView.ItemsLayout>
                    <VerticalListLayout Spacing="20"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#E2E8F0" StrokeThickness="1"
                                Background="#FFFFFF" StrokeShape="RoundRectangle 16"
                                Shadow="{Shadow Brush=#000000, Offset='0,8', Opacity=0.05, Radius=12}">
                            <VerticalStackLayout Padding="20" Spacing="8">
                                <Label Text="{Binding Name}" FontSize="20" FontAttributes="Bold" TextColor="#0F172A" />
                                <Label Text="{Binding Description}" FontSize="15" TextColor="#334155" MaxLines="3" LineBreakMode="WordWrap" />

                                <HorizontalStackLayout Spacing="12" Margin="0,16,0,0">
                                    <Border Stroke="#EA580C" StrokeThickness="1.5" Background="#FFF7ED" StrokeShape="RoundRectangle 8" Padding="12,6">
                                        <Label Text="{Binding Stops.Count, StringFormat='So diem: {0}'}" FontSize="13" FontAttributes="Bold" TextColor="#EA580C" />
                                    </Border>
                                    <Border Stroke="#E2E8F0" StrokeThickness="1" Background="#F8FAFC" StrokeShape="RoundRectangle 8" Padding="12,6">
                                        <Label Text="{Binding EstimatedMinutes, StringFormat='Thoi gian: {0} phut'}" FontSize="13" FontAttributes="Bold" TextColor="#475569" />
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,80,0,0">
                        <Label Text="Khong co lo trinh nao." TextColor="#475569" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" />
                        <Label Text="Thu dong bo lai hoac kiem tra ket noi API." TextColor="#64748B" FontSize="14" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
